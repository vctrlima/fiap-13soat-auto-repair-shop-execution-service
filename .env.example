# Server
SERVER_PORT=3004
SERVER_HOST=http://localhost:3004

# Database
DATABASE_URL=postgresql://user:password@localhost:5434/execution_db?connection_limit=5

# AWS
AWS_REGION=us-east-2
AWS_ENDPOINT_URL=http://localhost:4566

# SNS / SQS
SNS_EXECUTION_EVENTS_TOPIC_ARN=arn:aws:sns:us-east-2:000000000000:execution-events
SQS_EXECUTION_WORK_ORDER_QUEUE_URL=http://localhost:4566/000000000000/execution-work-order-queue
SQS_NOTIFICATION_QUEUE_URL=http://localhost:4566/000000000000/notification-queue

# Email
MAILING_ENABLED=false

# CORS (optional — defaults to '*')
CORS_ORIGIN=

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
LOG_LEVEL=info
